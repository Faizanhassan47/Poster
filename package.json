{
  "name": "background-removal-poster-app",
  "version": "1.0.0",
  "description": "Full-Stack Poster Studio with AI Background Removal & Template Management",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "install-all": "npm install && npm run install:frontend && npm run install:backend",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm start",
    "start": "node backend/server.js",
    "build": "npm run install:frontend && cd frontend && npm run build",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^137.0.0",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.2",
    "multer": "^1.4.5-lts.1"
  }

}
